{
  "name": "vaultforge-wallet",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "generate-icon": "tauri icon src-tauri/icons/icon.svg -o src-tauri/icons",
    "prepare-tauri": "npm run sync-cargo-version && npm run generate-icon",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "sync-cargo-version": "node scripts/sync-cargo-version.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
